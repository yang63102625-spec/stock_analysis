{
  "name": "daily-stock-analysis-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.daily-stock-analysis.desktop",
    "productName": "Daily Stock Analysis",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "../../.env.example",
        "to": ".env.example"
      },
      {
        "from": "../../dist/backend/stock_analysis",
        "to": "backend/stock_analysis"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "synopsis": "AI-powered stock analysis desktop launcher",
      "description": "Desktop launcher for the Daily Stock Analysis application."
    }
  }
}
